# Sales Intelligence (Personal Copy) environment template
# Copy the values you need into backend/.env for local development.

# IBM watsonx.ai Configuration
AI_INTEGRATIONS_IBM_WATSONX_API_KEY=your_ibm_watsonx_api_key_here
AI_INTEGRATIONS_IBM_WATSONX_PROJECT_ID=your_ibm_watsonx_project_id_here
AI_INTEGRATIONS_IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Optional alternate watsonx variable names supported by the backend
WATSONX_API_KEY=your_ibm_watsonx_api_key_here
WATSONX_PROJECT_ID=your_ibm_watsonx_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Optional Anthropic fallback/development configuration
AI_INTEGRATIONS_ANTHROPIC_API_KEY=your_anthropic_api_key_here
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com

# Server Configuration
NODE_ENV=development
PORT=3000

# Frontend / CORS
CORS_ORIGIN=http://localhost:5173